# The next line updates PATH for the Google Cloud SDK.
if [ -f "$HOME/.gcloud/path.zsh.inc" ]; then . "$HOME/.gcloud/path.zsh.inc"; fi

# The next line enables shell command completion for gcloud.
if [ -f "$HOME/.gcloud/completion.zsh.inc" ]; then . "$HOME/.gcloud/completion.zsh.inc"; fi

# NVM (lazy load)
export NVM_DIR="$HOME/.nvm"
nvm() { unalias nvm 2>/dev/null; source "$NVM_DIR/nvm.sh"; nvm "$@"; }

# FZF
[ -r ~/.fzf.zsh ] && . ~/.fzf.zsh

# FNM
FNM_PATH="$HOME/.local/share/fnm"
if [ -d "$FNM_PATH" ]; then
  export PATH="$HOME/.local/share/fnm:$PATH"
  eval "$(fnm env --use-on-cd --shell zsh)"
fi

# Terraform
mkdir -p $HOME/.terraform.d/plugin-cache

# TGENV
export TGENV_AUTO_INSTALL=true

# TFENV
export TFENV_AUTO_INSTALL=true

# GVM
export GVM_DIR="$HOME/.gvm"
[ -r "$GVM_DIR/scripts/gvm" ] && . "$GVM_DIR/scripts/gvm"

# Shell-GPT
_sgpt_zsh() {
  if [[ -n "$BUFFER" ]]; then
    _sgpt_prev_cmd=$BUFFER
    BUFFER+=" ⌛"
    zle -I && zle redisplay
    BUFFER=$(sgpt --shell --no-interaction <<<"$_sgpt_prev_cmd" | sed '/```/d')
    zle end-of-line
  fi
}
[ $(command -v sgpt) ] && zle -N _sgpt_zsh && bindkey '^z' _sgpt_zsh

# PYEnv (lazy load - shims work immediately, full init deferred to first pyenv call)
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/shims:$PYENV_ROOT/bin:$PATH"
export PYENV_SHELL=zsh
pyenv() { unfunction pyenv; eval "$(command pyenv init -)"; pyenv "$@"; }

# Podman
[ $(command -v podman) ] && [ $(podman machine inspect --format '{{.ConnectionInfo.PodmanSocket.Path}}') ] && export DOCKER_HOST=unix://$(podman machine inspect --format '{{.ConnectionInfo.PodmanSocket.Path}}')

# kubeswitch
if [ $(command -v switcher) ]; then
  _load_cached_completion switcher-init switcher init zsh
  alias s=switch
  _load_cached_completion switch-completion switch completion zsh
fi

# Kiro
[[ "$TERM_PROGRAM" == "kiro" ]] && . "$(kiro --locate-shell-integration-path zsh)"